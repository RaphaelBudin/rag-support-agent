# Copy to .env and fill in. .env is gitignored.

# --- Database ---
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# --- LLM / embedding provider (pluggable) ---
# LLM_PROVIDER=openai | anthropic | gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# EMBEDDING_PROVIDER=hash | openai | gemini  (hash is the keyless default)
#   gemini -> gemini-embedding-001 @ 1536-d (matches the pgvector column); needs GEMINI_API_KEY
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=gpt-4o-mini

# --- Behavior ---
# Below this confidence, the agent abstains instead of answering.
CONFIDENCE_ABSTAIN_THRESHOLD=0.55
RETRIEVAL_TOP_K=5

# --- Retrieval fusion + gate (M2) ---
RRF_K=60
# Drop a candidate unless dense cosine clears this floor OR sparse has a keyword hit.
# Provider-dependent (hash vs openai scales differ); calibrated on the eval set in M5.
RETRIEVAL_MIN_SIMILARITY=0.15
