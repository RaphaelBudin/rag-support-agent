# Copy to .env and fill in. .env is gitignored.

# --- Database ---
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# --- LLM / embedding provider (pluggable) ---
# LLM_PROVIDER (generation): extractive | gemini
#   extractive -> keyless default; answers from retrieved passages verbatim + citations
#   gemini     -> real synthesis via gemini-2.5-flash; needs GEMINI_API_KEY (put it in .env, NOT here)
LLM_PROVIDER=extractive
GEMINI_API_KEY=

# EMBEDDING_PROVIDER=hash | openai | gemini  (hash is the keyless default)
#   gemini -> gemini-embedding-001 @ 1536-d (matches the pgvector column); needs GEMINI_API_KEY
#   openai -> needs OPENAI_API_KEY
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
GENERATION_MODEL=gemini-2.5-flash

# --- Behavior ---
# M4: below this confidence the agent abstains instead of answering. Confidence is a
# retrieval *spread* (top-hit gap over the field, ~[0, 0.3]), not a cosine floor, so the
# threshold is on that scale. Provisional — M5 calibrates it against the labeled eval set.
CONFIDENCE_ABSTAIN_THRESHOLD=0.12
RETRIEVAL_TOP_K=5

# --- Retrieval fusion + gate (M2) ---
RRF_K=60
# Drop a candidate unless dense cosine clears this floor OR sparse has a keyword hit.
# Provider-dependent (hash vs openai scales differ); calibrated on the eval set in M5.
RETRIEVAL_MIN_SIMILARITY=0.15
